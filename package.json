{
  "name": "polyglot",
  "version": "1.0.0",
  "private": true,
  "description": "Free, open-source, local-first language learning. No ads, no telemetry, no signup wall.",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "test": "vitest run",
    "deck": "node packs/zh/build.mjs",
    "api-test": "node scripts/api-tests.mjs",
    "db:local": "wrangler d1 execute polyglot-db --local --file worker/schema.sql --config worker/wrangler.toml"
  },
  "dependencies": {
    "hanzi-writer": "3.7.3",
    "hanzi-writer-data": "2.0.1",
    "ts-fsrs": "5.4.1"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "subset-font": "2.5.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
